<%- include('partials/header', { title: "Giỏ hàng" }) %>

<section>
  <h2 class="section-title">Giỏ hàng của bạn</h2>

  <% if (cartItems.length === 0) { %>
    <p style="font-size:.9rem;color:var(--text-dim);">Giỏ hàng đang trống.</p>
    <a class="btn-primary" href="/" style="margin-top:1rem;display:inline-block;">
      ← Tiếp tục mua cây
    </a>
  <% } else { %>

    <% if (message) { %>
      <div style="margin-bottom:1rem;padding:.75rem;border-radius:10px;border:1px solid #f5c2c7;background:#f8d7da;color:#842029;">
        <%= message %>
      </div>
    <% } %>

    <div class="cart-card">
      <table class="cart-table">
        <thead>
          <tr>
            <th>Sản phẩm</th>
            <th>Đơn giá</th>
            <th>Số lượng</th>
            <th>Tạm tính</th>
            <th>Xóa</th>
          </tr>
        </thead>
        <tbody>
          <% cartItems.forEach(item => { %>
            <tr>
              <td>
                <div class="cart-item-main">
                  <img src="<%= item.productImg || '/images/default-plant.jpg' %>" class="cart-thumb" alt="<%= item.productName %>">
                  <div>
                    <div class="product-name"><%= item.productName %></div>
                    <% if (item.variant && (item.variant.variantName || item.variant.color || item.variant.size || item.variant.material)) { %>
                      <div class="product-desc">
                        <% if (item.variant.variantName) { %>Biến thể: <%= item.variant.variantName %><% } %>
                        <% if (item.variant.color) { %> | Màu: <%= item.variant.color %><% } %>
                        <% if (item.variant.size) { %> | Size: <%= item.variant.size %><% } %>
                        <% if (item.variant.material) { %> | Chất liệu: <%= item.variant.material %><% } %>
                      </div>
                    <% } %>
                  </div>
                </div>
              </td>

              <td class="product-price">
                <%= formatCurrency(item.price) %>
              </td>

              <td>
                <form class="qty-form" action="/cart/update/<%= item.productID %>" method="POST">
                  <input
                    type="number"
                    name="qty"
                    min="1"
                    value="<%= item.quantity %>"
                    class="qty-input"
                  />
                  <button class="btn-primary" style="font-size:.8rem;padding:.4rem .6rem;">Cập nhật</button>
                </form>
              </td>

              <td class="product-price">
                <%= formatCurrency(item.subTotal) %>
              </td>

              <td>
                <form action="/cart/remove/<%= item.productID %>" method="POST">
                  <button class="btn-danger" style="font-size:.8rem;padding:.4rem .6rem;">Xóa</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="cart-summary">
      <div>Tạm tính: <%= formatCurrency(cartSummary.subtotal) %></div>
      <div>Phí vận chuyển: <%= formatCurrency(cartSummary.shippingFee) %></div>
      <% if (cartSummary.discount > 0) { %>
        <div>Giảm giá: -<%= formatCurrency(cartSummary.discount) %></div>
      <% } %>
      <% if (cartSummary.pointsUsed > 0) { %>
        <div>Điểm đã dùng: -<%= formatCurrency(cartSummary.pointsValue) %> (<%= cartSummary.pointsUsed %> điểm)</div>
      <% } %>
      <strong style="display:block;margin-top:.5rem;">Tổng cộng: <%= formatCurrency(cartSummary.total) %></strong>
    </div>

    <div class="cart-actions">
      <a class="btn-primary" href="/checkout" style="min-width:200px;text-align:center;">
        Tiến hành đặt hàng (COD)
      </a>
      <a class="link-back" href="/">← Tiếp tục xem sản phẩm</a>
    </div>

  <% } %>
</section>

<%- include('partials/footer') %>
