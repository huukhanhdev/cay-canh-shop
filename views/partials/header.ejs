<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title || "Cây Cảnh Shop" %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .nav{display:flex;gap:1rem;align-items:center}
    .badge{background:#5ba25b;color:#fff;border-radius:18px;padding:.1rem .5rem;font-weight:700}
    .spacer{flex:1}
    .dropdown{position:relative}
    .dropdown-btn{background:transparent;border:1px solid #cfe3cf;border-radius:8px;padding:.4rem .6rem;cursor:pointer}
    .dropdown-menu{position:absolute;top:120%;left:0;min-width:220px;background:#fff;border:1px solid #dfe9df;border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,.05);display:none;z-index:20}
    .dropdown-menu.show{display:block}
    .dropdown-item{display:block;padding:.55rem .8rem;color:#234;text-decoration:none}
    .dropdown-item:hover{background:#f5faf5}
    .logout-form{display:inline}
    .nav-link{margin:0 .2rem}
  </style>
</head>
<body class="site-body">

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <span class="brand-icon">🌿</span>
      <span class="brand-text">Cây Cảnh Shop</span>
    </a>

    <nav class="nav">
      <a href="/" class="nav-link">Trang chủ</a>
      <a href="/products" class="nav-link">Sản phẩm</a>


      <span class="spacer"></span>

      <a href="/cart" class="nav-link">Giỏ hàng <span class="badge"><%= cartCount || 0 %></span></a>
      <a href="/contact" class="nav-link">Liên hệ</a>

      <% if (isLoggedIn && !isAdmin) { %>
        <a href="/orders/my" class="nav-link">🧾 Đơn hàng của tôi</a>
        <a href="/account/profile" class="nav-link">👤 Tài khoản</a>
      <% } %>

      <% if (isLoggedIn && isAdmin) { %>
        <div class="dropdown admin-dropdown">
          <button type="button" class="dropdown-btn">Admin ▾</button>
          <div class="dropdown-menu">
            <a class="dropdown-item" href="/admin/dashboard">📊 Dashboard</a>
            <a class="dropdown-item" href="/admin/products">🛠 Quản lý sản phẩm</a>
            <a class="dropdown-item" href="/admin/orders">📦 Quản lý đơn hàng</a>
            <a class="dropdown-item" href="/admin/categories">📚 Quản lý danh mục</a>
          </div>
        </div>
        <a href="/account/profile" class="nav-link">👤 Hồ sơ</a>
      <% } %>

      <% if (!isLoggedIn) { %>
        <a href="/login" class="nav-link">Đăng nhập</a>
        <a href="/register" class="nav-link">Đăng ký</a>
      <% } else { %>
        <form action="/logout" method="POST" class="logout-form">
          <button type="submit" class="nav-link" style="background:none;border:none;cursor:pointer;padding:0">
            🚪 Đăng xuất (<%= userName %>)
          </button>
        </form>
      <% } %>
    </nav>
  </div>
</header>

<main class="page-content container">
