<%- include('partials/header', { title: "Thêm sản phẩm mới" }) %>

<section style="max-width:560px;">
  <h2 class="section-title" style="margin-bottom:1rem;">Thêm sản phẩm mới</h2>

  <form action="/admin/products" method="POST" enctype="multipart/form-data" style="display:grid;gap:1rem;">
    <div>
      <label class="form-label" for="name">Tên cây</label>
      <input id="name" name="name" type="text" required class="form-input">
    </div>

    <div>
      <label class="form-label" for="slug">Slug (tự tạo nếu bỏ trống)</label>
      <input id="slug" name="slug" type="text" class="form-input" placeholder="vd: cay-luoi-ho">
    </div>

    <div>
      <label class="form-label" for="price">Giá (VND)</label>
      <input id="price" name="price" type="number" min="0" required class="form-input">
    </div>

    <div>
      <label class="form-label" for="type">Loại sản phẩm</label>
      <input id="type" name="type" type="text" class="form-input" placeholder="plant / pot ...">
    </div>

    <div>
      <label class="form-label" for="categoryID">Danh mục</label>
      <select id="categoryID" name="categoryID" class="form-input" required>
        <option value="">— Chọn danh mục —</option>
        <% (categories || []).forEach(c => { %>
          <option value="<%= c._id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </div>

    <div>
      <label class="form-label" for="inStock">Tổng tồn kho</label>
      <input id="inStock" name="inStock" type="number" min="0" value="0" class="form-input">
    </div>

    <div>
      <label class="form-label" for="description">Mô tả</label>
      <textarea id="description" name="description" rows="4" class="form-input"></textarea>
    </div>

    <div>
      <label class="form-label" for="img">Ảnh sản phẩm</label>
      <input id="img" name="img" type="file" accept="image/*" class="form-input">
      <p class="hint">Chọn hình từ máy (tối đa 5MB)</p>
    </div>

    <fieldset style="border:1px solid #dfe9df;border-radius:12px;padding:1rem;">
      <legend style="font-weight:600;color:#2e6b2e;">Chi tiết cây (Plant)</legend>
      <label class="form-label" for="plantHeight">Chiều cao</label>
      <input id="plantHeight" name="plantHeight" type="text" class="form-input" placeholder="Ví dụ: 30-40cm">

      <label class="form-label" for="plantDifficulty">Độ khó chăm</label>
      <input id="plantDifficulty" name="plantDifficulty" type="text" class="form-input" placeholder="Dễ / Trung bình / Khó">

      <label class="form-label" for="plantLight">Nhu cầu ánh sáng</label>
      <input id="plantLight" name="plantLight" type="text" class="form-input" placeholder="Ánh sáng gián tiếp">

      <label class="form-label" for="plantWater">Nhu cầu nước</label>
      <input id="plantWater" name="plantWater" type="text" class="form-input" placeholder="2 lần/tuần">
    </fieldset>

    <fieldset style="border:1px solid #dfe9df;border-radius:12px;padding:1rem;">
      <legend style="font-weight:600;color:#2e6b2e;">Chi tiết chậu (Pot)</legend>
      <label class="form-label" for="potMaterial">Chất liệu</label>
      <input id="potMaterial" name="potMaterial" type="text" class="form-input" placeholder="Gốm, nhựa...">

      <label class="form-label" for="potPattern">Họa tiết</label>
      <input id="potPattern" name="potPattern" type="text" class="form-input">

      <label class="form-label" for="potDimension">Kích thước</label>
      <input id="potDimension" name="potDimension" type="text" class="form-input" placeholder="Ví dụ: 12x12cm">

      <label class="form-label" for="potColor">Màu sắc</label>
      <input id="potColor" name="potColor" type="text" class="form-input">
    </fieldset>

    <div class="hint">Để trống các trường không phù hợp với loại sản phẩm.</div>

    <button class="btn btn-primary">Lưu sản phẩm</button>
    <a class="back-link" href="/admin/products">← Quay lại danh sách</a>
  </form>
</section>

<%- include('partials/footer') %>
