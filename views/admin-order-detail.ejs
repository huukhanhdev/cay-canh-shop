<%- include('partials/header', { title: "Chi tiết đơn hàng" }) %>

<section class="checkout-wrapper">
  <h2 class="section-title">Chi tiết đơn hàng</h2>

  <div class="checkout-box">
  <h3>Thông tin đơn hàng</h3>

  <div style="font-size:.9rem;line-height:1.5;display:grid;row-gap:.5rem;">
    <div><strong>Mã đơn:</strong> <%= order._id %></div>

    <div><strong>Trạng thái hiện tại:</strong>
      <% if (order.status === 'pending') { %>
        ⏳ Chờ xử lý
      <% } else if (order.status === 'preparing') { %>
        🛠️ Đang chuẩn bị
      <% } else if (order.status === 'shipping') { %>
        🚚 Đang giao
      <% } else if (order.status === 'done') { %>
        🎉 Hoàn tất
      <% } else if (order.status === 'canceled') { %>
        ❌ Đã hủy
      <% } else { %>
        <%= order.status %>
      <% } %>
    </div>

    <div><strong>Thời gian tạo:</strong> <%= order.createdAt.toLocaleString('vi-VN') %></div>
    <% if (order.updatedAt) { %>
      <div><strong>Cập nhật cuối:</strong> <%= order.updatedAt.toLocaleString('vi-VN') %></div>
    <% } %>
    <% if (order.status === 'canceled' && order.cancelReason) { %>
      <div><strong>Lý do hủy:</strong> <%= order.cancelReason %></div>
      <% if (order.canceledAt) { %>
        <div><strong>Thời gian hủy:</strong> <%= new Date(order.canceledAt).toLocaleString('vi-VN') %></div>
      <% } %>
    <% } %>
    <div><strong>Điểm thưởng khi hoàn tất:</strong> <%= order.pointEarned || 0 %> điểm (<%= order.pointRewarded ? 'Đã cộng' : 'Chưa cộng' %>)</div>
  </div>

  <!-- đổi trạng thái -->
  <form id="statusForm"
        action="/admin/orders/<%= order._id %>/status"
        method="POST"
        class="status-form"
        style="margin-top:1rem;display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;">
    <label for="status" style="font-weight:600;">Cập nhật trạng thái:</label>

    <select id="status" name="status" class="status-select">
      <option value="pending"   <%= order.status === 'pending' ? 'selected' : '' %>>⏳ Chờ xử lý</option>
      <option value="preparing" <%= order.status === 'preparing' ? 'selected' : '' %>>🛠️ Chuẩn bị</option>
      <option value="shipping"  <%= order.status === 'shipping' ? 'selected' : '' %>>🚚 Đang giao</option>
      <option value="done"      <%= order.status === 'done' ? 'selected' : '' %>>🎉 Hoàn tất</option>
      <option value="canceled"  <%= order.status === 'canceled' ? 'selected' : '' %>>❌ Đã hủy</option>
    </select>

    <button type="submit" class="btn-secondary">Cập nhật trạng thái</button>
  </form>

  <!-- nút sửa thông tin khách -->
  <div style="margin-top:1rem;">
    <a class="btn-primary" href="/admin/orders/<%= order._id %>/edit">
      ✍️ Sửa thông tin khách
    </a>
  </div>

  <!-- nút xoá đơn -->
  <form action="/admin/orders/<%= order._id %>/delete"
        method="POST"
        onsubmit="return confirm('Bạn có chắc muốn xoá đơn hàng này không?');"
        style="margin-top:1rem;">
    <button type="submit" class="btn-danger">🗑️ Xóa đơn hàng</button>
  </form>
</div>

  <div class="checkout-box">
    <h3>Thông tin khách hàng</h3>
    <div style="font-size:.9rem;line-height:1.5;">
      <div><strong>Tên:</strong> <%= order.customerName %></div>
      <div><strong>Email:</strong> <%= order.customerEmail || '—' %></div>
      <div><strong>Địa chỉ:</strong> <%= order.addressText %></div>
    </div>
  </div>

  <div class="checkout-box">
    <h3>Sản phẩm</h3>
    <ul class="checkout-items">
      <% order.items.forEach(it => { %>
        <li class="checkout-item-row">
          <div class="checkout-item-left">
            <img src="<%= it.image %>" alt="<%= it.productName %>" class="checkout-thumb" />
            <div>
              <div class="checkout-item-name"><%= it.productName %></div>
              <div class="checkout-item-meta">Loại: <%= it.type || '—' %></div>
              <% if (it.variant && (it.variant.variantName || it.variant.color || it.variant.size || it.variant.material)) { %>
                <div class="checkout-item-meta">
                  <% if (it.variant.variantName) { %>Biến thể: <%= it.variant.variantName %><% } %>
                  <% if (it.variant.color) { %> | Màu: <%= it.variant.color %><% } %>
                  <% if (it.variant.size) { %> | Kích thước: <%= it.variant.size %><% } %>
                  <% if (it.variant.material) { %> | Chất liệu: <%= it.variant.material %><% } %>
                </div>
              <% } %>
              <div class="checkout-item-meta">SL: <%= it.quantity %></div>
              <div class="checkout-item-meta">Đơn giá: <%= it.price.toLocaleString('vi-VN') %>₫</div>
            </div>
          </div>
          <div class="checkout-item-price">
            <%= formatCurrency(it.subTotal || it.quantity * it.price) %>
          </div>
        </li>
      <% }) %>
    </ul>

    <div class="checkout-total">
      <div>Tạm tính: <%= formatCurrency((order.totalPrice || 0) - (order.shippingFee || 0) + (order.discount || 0)) %></div>
      <div>Phí vận chuyển: <%= formatCurrency(order.shippingFee || 0) %></div>
      <div>Giảm giá: -<%= formatCurrency(order.discount || 0) %></div>
      <div>Điểm đã dùng: -<%= formatCurrency(order.pointsValue || 0) %> (<%= order.pointUsed || 0 %> điểm)</div>
      <strong>Tổng cộng: <%= formatCurrency(order.totalPrice || 0) %></strong>
    </div>
  </div>

  <div>
    <a class="btn-primary" href="/admin/orders" style="text-align:center;display:inline-block;">
      ← Quay lại danh sách đơn
    </a>
  </div>
</section>

<%- include('partials/footer') %>
